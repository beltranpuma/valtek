# ===============================
# Activar el motor de reescritura
# ===============================
RewriteEngine On

# Rutas amigables para páginas sueltas (.php)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(nosotros|contactos)/?$ $1.php [L]

# Rutas amigables para subcarpetas de productos
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ $1/index.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ $1/index.php [L]

# ============================================================
# OPTIMIZACIÓN DE RENDIMIENTO (Solución Lighthouse)
# ============================================================

# 1. COMPRESIÓN GZIP (Reduce el tamaño de transferencia de CSS/JS)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>

# 2. CACHÉ DEL NAVEGADOR (Soluciona el error "None" en tiempo de vida)
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Imágenes: 1 año de caché (Soluciona ahorro de 25MB)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS y JS: 1 mes de caché (Soluciona bloqueo de renderizado)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Fuentes y otros
    ExpiresByType font/truetype "access plus 1 year"
    ExpiresByType font/opentype "access plus 1 year"
    ExpiresByType application/x-font-woff "access plus 1 year"
</IfModule>

# 3. SEGURIDAD BÁSICA (Prácticas recomendadas de Lighthouse)
Header set X-Content-Type-Options "nosniff"